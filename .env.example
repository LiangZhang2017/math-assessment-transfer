# Copy to .env and fill in your values
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_VERSION=2025-04-01-preview
AZURE_OPENAI_MODEL=gpt-4

# Reasoning-style models (e.g. gpt-5-tp): only max_completion_tokens is sent; no temperature, no max_tokens.
# Comma-separated deployment names. Default: gpt-5-tp
# AZURE_OPENAI_REASONING_MODELS=gpt-5-tp
